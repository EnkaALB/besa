# Supabase (EU/Frankfurt) — projet créé sur https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : JAMAIS exposé côté client. Lu uniquement par /api/* serveur.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — émails transactionnels (free tier, https://resend.com)
RESEND_API_KEY=

# URL publique du site (pour les liens dans les emails et les magic links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret partagé entre Vercel Cron et l'endpoint /api/cron/*
CRON_SECRET=

# Upstash Redis pour le rate limiting (free tier 10k commandes/jour)
# Si absent, le rate limiting est désactivé (no-op) — utile en dev.
# Créer un Redis sur https://upstash.com/ ou via Vercel → Storage → KV.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
